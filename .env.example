DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ddp0_grader

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
PORT=8080

ALLOWED_ORIGINS=http://localhost:5174

AUTH_JWT_SECRET=unsafe-default-key
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_USER_ID_CLAIM=user_id
AUTH_JWT_TOKEN_TYPE_CLAIM=token_type
AUTH_JWT_ACCESS_TOKEN_TYPE=access

# Existing Django Admin endpoint used by grader to authorize problem/testcase writers.
# It must be reachable from the grader process/container.
DJANGO_ADMIN_ME_URL=http://localhost:8000/api/admin/me/
DJANGO_ME_URL=http://localhost:8000/api/auth/me
