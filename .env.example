DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ddp0_grader

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
PORT=8080

# Optional S3-compatible object storage for problem thumbnails.
s3_access_key_id=your-access-key-id
s3_secret_access_key=your-secret-access-key
s3_endpoint_url=url-to-your-s3-endpoint
s3_bucket_name=your-bucket-name
s3_region=us-east-1
# Use v2 only for legacy S3-compatible providers. MinIO uses v4.
s3_signature_version=v4

ALLOWED_ORIGINS=http://localhost:5174

AUTH_JWT_SECRET=unsafe-default-key
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_USER_ID_CLAIM=user_id
AUTH_JWT_TOKEN_TYPE_CLAIM=token_type
AUTH_JWT_ACCESS_TOKEN_TYPE=access

# Existing Django Admin endpoint used by grader to authorize problem/testcase writers.
# It must be reachable from the grader process/container.
DJANGO_ADMIN_ME_URL=http://localhost:8000/api/admin/me/
DJANGO_ME_URL=http://localhost:8000/api/auth/me
